{
  "compilerOptions": {
    "target": "ES2024", // Define para qual versao do JavaScript o TypeScript vai compilar.
    "lib": ["ES2024"], // Libera os tipos das APIs modernas do JavaScript disponiveis nesse padrao.

    "paths": {
      "@/*": ["./src/*"] // Permite usar @/ para importar arquivos da pasta src.
    },

    "module": "nodenext", // Faz o TS seguir o comportamento de modulos do Node moderno. 
    "esModuleInterop": true, // Melhora a compatibilidade ao importar pacotes CommonJS, como o Express.
    "forceConsistentCasingInFileNames": true, // Evita problemas com maiusculas/minusculas em nomes de arquivos.

    "strict": true, // Ativa as checagens mais rigidas de tipos.
    "skipLibCheck": true, // Ignora a checagem de tipos dentro das bibliotecas para compilar mais rapido.
  },
}




